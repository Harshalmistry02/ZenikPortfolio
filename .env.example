# Database (Neon, PlanetScale, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET="your-strong-random-secret-min-32-chars"
JWT_REFRESH_SECRET="your-strong-random-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=5

# CORS
ALLOWED_ORIGINS="http://localhost:3000"

# Email Service (for form notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@zenik.studio"

# Admin Settings
ADMIN_EMAIL="admin@zenik.studio"
ADMIN_NOTIFICATION_EMAIL="your-email@zenik.studio"

# Form Settings
CONTACT_FORM_ENABLED="true"
PROJECT_INQUIRY_ENABLED="true"
NEWSLETTER_ENABLED="true"
